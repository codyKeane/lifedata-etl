# LifeData V4 — .gitignore
# ──────────────────────────────────────────────────────────────
# The ONLY files that should be version-controlled are:
#   - core/        (ETL engine code)
#   - modules/     (module code)
#   - analysis/    (analysis engine code)
#   - scripts/     (API fetch scripts)
#   - run_etl.py   (entry point)
#   - config.yaml  (tracked for structure, but keys are ${ENV_VAR} refs)
#   - .gitignore
#
# Everything else is data, secrets, or ephemeral.
# ──────────────────────────────────────────────────────────────

# Secrets — NEVER commit
.env
*.env*

# ETL lockfile (flock-based, prevents concurrent runs)
.etl.lock

# Database — contains all personal data
db/*.db
db/backups/

# Raw data — Syncthing landing zone
raw/

# Binary media files
/media/

# Generated reports (contain personal data summaries)
reports/

# Logs
logs/

# Python virtual environment
venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Type checking / linting / testing caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Packaging
*.egg-info/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Backup files
*.bak
*.bak.*

# V3 legacy (archived to legacy/, not tracked)
legacy/

# Claude Code settings
.claude

# Coverage reports
.coverage

# Syncthing metadata
.stfolder/
.stignore

# ETL log (ephemeral)
etl.log
